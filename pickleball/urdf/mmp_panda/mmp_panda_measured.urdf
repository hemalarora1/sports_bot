<?xml version='1.0' encoding='utf-8'?>

<robot name="mmp_panda" version="1.0">

  <!-- GROUND LINK -->
  <link name ="ground_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1E-06" ixy="0.0" ixz="0.0" iyy="1E-06" iyz="0.0" izz="1E-06" />
    </inertial>
  </link>


  <!-- MOBILE BASE LINKS -->
  <link name ="base_x">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1E-06" ixy="0.0" ixz="0.0" iyy="1E-06" iyz="0.0" izz="1E-06" />
    </inertial>
  </link>

  <link name = "base_y">
    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <mass value = "0.001" />
      <inertia ixx="1E-06" ixy="0.0" ixz="0.0" iyy="1E-06" iyz="0.0" izz="1E-06" />
    </inertial>
  </link>

  <!-- MOBILE BASE + LINK 0 OF PANDA ARM -->
  <!-- Measured base dimensions (meters):
       length x = 0.544, width y = 0.502, height z = 0.444
       arm mount is centered in y and 0.09 m from front (+x), so x = 0.544/2 - 0.09 = 0.182 -->
  <link name = "base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.222" rpy="0 0 0" />
      <mass value = "64.6" />
      <!-- Approximate box inertia about COM -->
      <inertia ixx="2.417" ixy="0.0" ixz="0.0" iyy="2.653" iyz="0.0" izz="2.949" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.222" rpy="0 0 0"/>
      <geometry>
        <box size="0.544 0.502 0.444" />
      </geometry>
    </visual>
    <!-- Add a simple Franka mount pedestal so the measured model keeps the
         visible arm base mounting feature from the original mesh. -->
    <visual>
      <origin xyz="0.182 0 0.489" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.058" length="0.090" />
      </geometry>
    </visual>
    <visual>
      <origin xyz="0.182 0 0.446" rpy="0 0 0"/>
      <geometry>
        <box size="0.120 0.110 0.004" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.222" rpy="0 0 0"/>
      <geometry>
        <box size="0.544 0.502 0.444" />
      </geometry>
    </collision>
  </link>

